    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "react": "^19.0.4",
    "react-dom": "^19.0.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "typescript": "^6",
    "wxt": "^0.20.20"
  }
}
