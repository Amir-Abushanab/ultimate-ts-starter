# ─── Database ────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/ultimate-ts-starter"
# Hyperdrive uses this for local dev (should match DATABASE_URL)
CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE="postgresql://user:password@localhost:5432/ultimate-ts-starter"

# ─── Auth (Better Auth) ─────────────────────────
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# ─── CORS ────────────────────────────────────────
CORS_ORIGIN="http://localhost:3001"

# ─── Environment ─────────────────────────────────
NODE_ENV="development"

# ─── Email (Resend) ─────────────────────────────
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── Payments (Polar) ───────────────────────────
POLAR_ACCESS_TOKEN="your_polar_access_token"
POLAR_PRODUCT_ID="your_polar_product_id"
POLAR_SUCCESS_URL="http://localhost:3001/success"

# ─── Analytics (PostHog, optional) ──────────────
# Leave empty to disable analytics, session replay,
# error tracking, and remote feature flags.
# POSTHOG_API_KEY=""
# POSTHOG_HOST="https://us.i.posthog.com"

# ─── Social Login (optional) ────────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Web (client-side, prefixed) ────────────────
VITE_SERVER_URL="http://localhost:3000"
# VITE_POSTHOG_KEY=""
# VITE_POSTHOG_HOST="https://us.i.posthog.com"

# ─── Native (client-side, prefixed) ─────────────
EXPO_PUBLIC_SERVER_URL="http://localhost:3000"
# EXPO_PUBLIC_POSTHOG_KEY=""
# EXPO_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
